<!DOCTYPE html>
<html lang="en-GB">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="{{ branding.get('subtitle', 'Daily cyber threat landscape briefing') }}">
  <title>{{ branding.get('page_title', 'Cyber Threat Landscape Today') }} — {{ branding.get('site_name', '') }}</title>
  <!-- Open Graph -->
  <meta property="og:type"        content="website">
  <meta property="og:title"       content="{{ branding.get('page_title', 'Cyber Threat Landscape Today') }}">
  <meta property="og:description" content="{{ branding.get('subtitle', 'A daily briefing on the top active cyber threats') }}">
  {% if branding.get('site_url') %}<meta property="og:url" content="{{ branding.site_url }}">{% endif %}
  <!-- Twitter / X -->
  <meta name="twitter:card"        content="summary">
  <meta name="twitter:title"       content="{{ branding.get('page_title', 'Cyber Threat Landscape Today') }}">
  <meta name="twitter:description" content="{{ branding.get('subtitle', 'A daily briefing on the top active cyber threats') }}">
  <link rel="stylesheet" href="static/style.css">
  <style>
    .site-nav{display:flex;gap:.6rem;margin-top:.9rem;flex-wrap:wrap}
    .btn-nav{display:inline-flex;align-items:center;gap:.35rem;padding:.35rem .85rem;border-radius:6px;font-size:.78rem;font-weight:600;text-decoration:none;border:1.5px solid transparent;transition:background .15s,color .15s,border-color .15s;white-space:nowrap}
    .btn-nav--site{background:#f4f4f5;color:#374151;border-color:#d1d5db}.btn-nav--site:hover{background:#e5e7eb}
    .btn-nav--aiml{background:#ede9fe;color:#4c1d95;border-color:#a78bfa}.btn-nav--aiml:hover{background:#ddd6fe}
    .countdown-wrap{display:flex;align-items:center;gap:.5rem;margin-top:.5rem;font-size:.78rem;color:#6b7280}
    .countdown-value{font-variant-numeric:tabular-nums;font-weight:700;color:#dc2626;min-width:5.5rem}
    .countdown-caveat{font-size:.72rem;color:#9ca3af}
  </style>
</head>
<body>

<!-- ═══════════════════════════════════════════════════════ HEADER -->
<header class="site-header">
  <div class="container">
    <div class="header-inner">
      <div class="header-text">
        <p class="header-eyebrow">{{ branding.get('site_name', 'Security Intelligence') }}</p>
        <h1 class="header-title">{{ branding.get('page_title', 'Cyber Threat Landscape Today') }}</h1>
        <p class="header-subtitle">{{ branding.get('subtitle', 'A daily briefing on the top active cyber threats') }}</p>
      </div>
      <div class="header-meta">
        <div class="updated-badge">
          <span class="updated-label">Last updated</span>
          <span class="updated-value">{{ generated_at }}</span>
        </div>
        <div class="stats-pills">
          <span class="stat-pill">Today&rsquo;s top {{ threats|length }}</span>
          <span class="stat-pill">{{ total_collected }} articles analysed</span>
          {% if total_after_dedupe > 0 %}
          <span class="stat-pill">{{ total_after_dedupe }} unique stories</span>
          {% endif %}
          {% if source_health_summary %}
          <span class="stat-pill stat-pill--health-{{ source_health_summary.cls }}"
                title="{{ source_health_summary.healthy }}/{{ source_health_summary.total }} sources returned items today">
            {{ source_health_summary.healthy }}/{{ source_health_summary.total }} sources active
          </span>
          {% endif %}
        </div>
        <div class="countdown-wrap" aria-live="polite">
          <span>Next refresh in</span>
          <span id="refresh-countdown" class="countdown-value" aria-label="Countdown to next refresh">--:--:--</span>
          <span class="countdown-caveat">(approx. 09:00 UTC &mdash; may vary slightly)</span>
        </div>
        <nav class="site-nav" aria-label="Related pages">
          <a href="aiml/index.html" class="btn-nav btn-nav--aiml">
            AI/ML &rarr;
          </a>
          <a href="conferences/index.html" class="btn-nav btn-nav--conferences">
            Conferences &rarr;
          </a>
          <a href="{{ branding.get('site_url', 'https://barrycheevers.co.uk') }}" class="btn-nav btn-nav--site" target="_blank" rel="noopener noreferrer">
            Barry Cheevers &nearr;
          </a>
          <button id="dark-mode-toggle" class="btn-dark-mode" title="Toggle dark mode" aria-label="Toggle dark mode">
            <span class="icon-moon" aria-hidden="true">&#9790;</span>
            <span class="icon-sun"  aria-hidden="true">&#9728;</span>
          </button>
        </nav>
      </div>
    </div>
  </div>
</header>

<!-- ═══════════════════════════════════════════════════════ MAIN -->
<main class="site-main">
  <div class="container">

    {% if generation_notes %}
    <div class="pipeline-notices">
      {% for note in generation_notes %}
      <p class="pipeline-notice">{{ note }}</p>
      {% endfor %}
    </div>
    {% endif %}

    {% if threats %}

    {# ── Card macro — shared by both technical and mainstream lists ── #}
    {% macro threat_card(threat, rank) %}
    <li class="threat-card" id="threat-{{ threat.list_idx }}"
        data-stream="{{ threat.stream }}"
        data-title="{{ threat.title | lower }}"
        data-sectors="{{ threat.industries_affected | join(',') | lower }}"
        data-sources="{{ threat.primary_source | lower }}"
        data-threat-types="{{ threat.threat_types | join(',') | lower }}">

      <div class="card-header">
        <div class="rank-badge" aria-label="Rank {{ rank }}">
          <span class="rank-number">{{ rank }}</span>
        </div>
        <div class="card-title-block">
          <h2 class="card-title">
            <a href="{{ threat.primary_url }}" target="_blank" rel="noopener noreferrer"
               class="card-title-link">{{ threat.title }}</a>
          </h2>
          <div class="card-meta-line">
            {% for tt in threat.threat_types %}
            <span class="threat-type-badge threat-type-badge--{{ tt | lower | replace(' ', '-') | replace('/', '-') }}">{{ tt }}</span>
            {% endfor %}
            <span class="source-badge">{{ threat.primary_source }}</span>
            {% for src in threat.supporting_sources[:3] %}
            <span class="source-badge source-badge--secondary">{{ src }}</span>
            {% endfor %}
            {% if threat.supporting_sources|length > 3 %}
            <span class="source-badge source-badge--secondary"
                  title="Also: {{ threat.supporting_sources[3:] | join(', ') }}">+{{ threat.supporting_sources|length - 3 }} more</span>
            {% endif %}
            <span class="meta-separator">&middot;</span>
            <span class="pub-date">{{ threat.published_at }}</span>
            {% if threat.corroboration_count > 1 %}
            <span class="meta-separator">&middot;</span>
            <span class="corroboration-badge" title="Also reported by: {{ threat.supporting_sources | join(', ') }}">
              {{ threat.corroboration_count }} outlets
            </span>
            {% endif %}
            {% if threat.prevalent_days >= 2 %}
            <span class="meta-separator">&middot;</span>
            <span class="prevalent-badge" title="This threat has appeared in the top 10 for {{ threat.prevalent_days }} consecutive days">
              Prevalent {{ threat.prevalent_days }}d
            </span>
            {% endif %}
          </div>
        </div>
        <div class="card-score" aria-label="Relevance score {{ threat.score }}">
          <span class="score-value">{{ "%.2f"|format(threat.score) }}</span>
          <span class="score-tier score-tier--{{ threat.score_tier }}">{{ threat.score_tier_label }}</span>
          <div class="score-tooltip-data" hidden aria-hidden="true">
            <p class="stt-total">Score: {{ "%.4f"|format(threat.score) }}</p>
            <table class="stt-table">
              {% for dim, val in threat.score_breakdown.items() %}
              {% if dim != 'total' %}
              <tr data-dim="{{ dim }}">
                <td>{{ dim | replace("_", " ") | title }}</td>
                <td>{{ "%.3f"|format(val) }}</td>
              </tr>
              {% endif %}
              {% endfor %}
            </table>
          </div>
        </div>
      </div>

      <div class="card-body">
        <p class="card-summary">{{ threat.summary }}</p>
      </div>

      <div class="badge-row">
        {% if threat.stream == 'technical' %}
        {% for tech in threat.attack_techniques %}
        <a href="{{ tech.url }}" target="_blank" rel="noopener noreferrer"
           class="badge badge--attack" title="{{ tech.tactic }}">
          {{ tech.id }}: {{ tech.name }}
        </a>
        {% endfor %}
        {% for cve in threat.cves %}
        {% set cve_data = threat.cve_details.get(cve) if threat.cve_details else none %}
        <a href="https://nvd.nist.gov/vuln/detail/{{ cve }}"
           target="_blank" rel="noopener noreferrer"
           class="badge badge--cve"
           {% if cve_data %}title="CVSS {{ cve_data.score }} ({{ cve_data.severity }})"{% endif %}>
          {{ cve }}{% if cve_data %}<span class="cve-score cve-score--{{ cve_data.severity | lower }}">{{ cve_data.score }}</span>{% endif %}
        </a>
        {% endfor %}
        {% endif %}
        {% for mal in threat.malware_families %}
        <span class="badge badge--malware">{{ mal }}</span>
        {% endfor %}
        {% for sector in threat.industries_affected %}
        {% if sector != "Unknown" %}
        <span class="badge badge--sector">{{ sector }}</span>
        {% endif %}
        {% endfor %}
        {% for country in threat.countries_affected %}
        {% if country != "Unknown" %}
        <span class="badge badge--country">{{ country }}</span>
        {% endif %}
        {% endfor %}
        {% if threat.stream == 'mainstream' %}
        {% for co in threat.companies_affected %}
        <span class="badge badge--company">{{ co }}</span>
        {% endfor %}
        {% endif %}
      </div>

      <div class="card-footer">
        <button class="expand-toggle"
                aria-expanded="false"
                aria-controls="detail-{{ threat.list_idx }}"
                data-idx="{{ threat.list_idx }}">
          <span class="expand-label"></span>
          <svg class="expand-icon" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd"
              d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0
                 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"
              clip-rule="evenodd"/>
          </svg>
        </button>
        {% if threat.stream == 'technical' %}
        <div class="stix-actions">
          {% if threat.stix_json %}
          <button class="btn-stix btn-stix--copy"
                  data-stix="{{ threat.list_idx }}"
                  title="Copy STIX 2.1 JSON to clipboard">
            Copy STIX
          </button>
          {% endif %}
          {% if threat.stix_file %}
          <a href="{{ threat.stix_file }}" download class="btn-stix btn-stix--download"
             title="Download STIX 2.1 JSON file">
            Download STIX
          </a>
          {% endif %}
        </div>
        {% endif %}
      </div>

      <div class="detail-panel" id="detail-{{ threat.list_idx }}" hidden>

        {% if threat.why_it_matters %}
        <div class="detail-section">
          <h3 class="detail-heading">Why it matters</h3>
          <p class="detail-text">{{ threat.why_it_matters }}</p>
        </div>
        {% endif %}

        {% if threat.stream == 'technical' and threat.attack_techniques %}
        <div class="detail-section">
          <h3 class="detail-heading">MITRE ATT&amp;CK</h3>
          <table class="attack-table">
            <thead>
              <tr><th>Technique</th><th>Name</th><th>Tactic</th><th>Confidence</th></tr>
            </thead>
            <tbody>
              {% for tech in threat.attack_techniques %}
              <tr>
                <td><a href="{{ tech.url }}" target="_blank" rel="noopener noreferrer" class="attack-link">{{ tech.id }}</a></td>
                <td>{{ tech.name }}</td>
                <td>{{ tech.tactic }}</td>
                <td><span class="confidence-badge confidence-badge--{{ tech.confidence | lower }}">{{ tech.confidence }}</span></td>
              </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
        {% endif %}

        {% if threat.attribution %}
        <div class="detail-section">
          <h3 class="detail-heading">Attribution</h3>
          <ul class="attribution-list">
            {% for attr in threat.attribution %}
            <li class="attribution-item">
              <strong>{{ attr.name }}</strong>
              <span class="confidence-badge confidence-badge--{{ attr.confidence | lower }}">
                {{ attr.confidence }} confidence
              </span>
              {% if attr.statement %}
                <span class="attr-statement">{{ attr.statement }}</span>
                {% endif %}
              </li>
              {% endfor %}
            </ul>
          </div>
          {% endif %}

          <!-- Scope -->
          <div class="detail-section detail-section--grid">
            {% if threat.countries_affected and threat.countries_affected != ["Unknown"] %}
            <div>
              <h3 class="detail-heading">Countries affected</h3>
              <div class="badge-group">
                {% for c in threat.countries_affected %}
                <span class="badge badge--country">{{ c }}</span>
                {% endfor %}
              </div>
            </div>
            {% endif %}

            {% if threat.industries_affected and threat.industries_affected != ["Unknown"] %}
            <div>
              <h3 class="detail-heading">Industries affected</h3>
              <div class="badge-group">
                {% for s in threat.industries_affected %}
                <span class="badge badge--sector">{{ s }}</span>
                {% endfor %}
              </div>
            </div>
            {% endif %}

            {% if threat.companies_affected %}
            <div>
              <h3 class="detail-heading">Companies mentioned</h3>
              <div class="badge-group">
                {% for co in threat.companies_affected %}
                <span class="badge badge--company">{{ co }}</span>
                {% endfor %}
              </div>
            </div>
            {% endif %}
          </div>

          <div class="detail-section">
            <h3 class="detail-heading">Score breakdown</h3>
            {% set ns = namespace(max_dim=0.001) %}
            {% for dim, val in threat.score_breakdown.items() %}
              {% if dim != 'total' and val > ns.max_dim %}{% set ns.max_dim = val %}{% endif %}
            {% endfor %}
            <div class="score-grid">
              {% for dim, val in threat.score_breakdown.items() %}
              {% if dim != "total" %}
              {% set bar_pct = ((val / ns.max_dim) * 100) | int if ns.max_dim > 0 else 0 %}
              <div class="score-dim" data-dim="{{ dim }}">
                <span class="score-dim-name">{{ dim | replace("_", " ") | title }}</span>
                <div class="score-bar-track" title="{{ "%.0f"|format(bar_pct) }}% of top dimension">
                  <div class="score-bar-fill" style="width: {{ bar_pct }}%"></div>
                </div>
                <span class="score-dim-val">{{ "%.3f"|format(val) }}</span>
              </div>
              {% endif %}
              {% endfor %}
            </div>
          </div>

          {% if threat.supporting_source_details %}
          <div class="detail-section">
            <h3 class="detail-heading">Also reported by</h3>
            <ul class="supporting-sources-list">
              {% for src in threat.supporting_source_details %}
              <li>
                <a href="{{ src.url }}" target="_blank" rel="noopener noreferrer"
                   class="supporting-source-link">
                  <span class="badge badge--source">{{ src.name }}</span>
                  <span class="supporting-source-url">{{ src.url }}</span>
                </a>
              </li>
              {% endfor %}
            </ul>
          </div>
          {% elif threat.supporting_sources %}
          <div class="detail-section">
            <h3 class="detail-heading">Also reported by</h3>
            <div class="badge-group">
              {% for src in threat.supporting_sources %}
              <span class="badge badge--source">{{ src }}</span>
              {% endfor %}
            </div>
          </div>
          {% endif %}

          {% if threat.confidence_note %}
          <div class="detail-section">
            <p class="confidence-note">
              <strong>Analytical note:</strong> {{ threat.confidence_note }}
            </p>
          </div>
          {% endif %}

          {% if threat.stream == 'technical' and threat.stix_json %}
          <div class="detail-section stix-section">
            <h3 class="detail-heading">STIX 2.1 Bundle</h3>
            <pre class="stix-pre" id="stix-pre-{{ threat.list_idx }}">{{ threat.stix_json }}</pre>
          </div>
          {% endif %}

        </div><!-- /detail-panel -->
      </li>
    {% endmacro %}

    <!-- ── View toggle ──────────────────────────────────────────────── -->
    <div class="view-toggle-bar" role="group" aria-label="Switch view">
      <button class="view-toggle-btn active" data-view="technical" aria-pressed="true">
        <svg class="view-toggle-icon" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M10 2L3 5.5V10c0 4 2.8 7.7 7 8.9 4.2-1.2 7-4.9 7-8.9V5.5L10 2z"
                stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
        </svg>
        <span class="view-toggle-label">Technical</span>
        <span class="view-toggle-desc">Expert threat analysis</span>
      </button>
      <button class="view-toggle-btn" data-view="mainstream" aria-pressed="false">
        <svg class="view-toggle-icon" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <rect x="2" y="3" width="16" height="11" rx="2" stroke="currentColor" stroke-width="1.5"/>
          <path d="M6 17h8M10 14v3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        <span class="view-toggle-label">Mainstream</span>
        <span class="view-toggle-desc">Public impact &amp; breaches</span>
      </button>
    </div>

    <!-- ── Search / filter toolbar ──────────────────────────────────── -->
    <div class="toolbar">
      <div class="toolbar-row">
        <div class="search-wrap">
          <svg class="search-icon" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <circle cx="8.5" cy="8.5" r="5.5" stroke="currentColor" stroke-width="1.6"/>
            <path d="M13 13l3.5 3.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
          </svg>
          <input
            type="search"
            id="threat-search"
            class="search-input"
            placeholder="Filter threats by keyword..."
            aria-label="Filter threats"
          >
        </div>
        <button id="clear-filters" class="btn-clear-filters" type="button">Clear filters</button>
      </div>
      <div class="filter-groups-row">
        <div class="filter-group" id="filter-group-types">
          <span class="filter-group-label">Threat type</span>
          <div class="filter-chips" id="threat-type-filters" aria-label="Filter by threat type">
            <!-- populated by JS -->
          </div>
        </div>
        <div class="filter-group" id="filter-group-sectors">
          <span class="filter-group-label">Industry</span>
          <div class="filter-chips" id="sector-filters" aria-label="Filter by sector">
            <!-- populated by JS -->
          </div>
        </div>
      </div>
    </div>

    <!-- ── Technical threats list ──────────────────────────────────── -->
    <ol class="threat-list" id="threat-list-technical" aria-label="Top technical cyber threats">
      {% for threat in threats %}
      {{ threat_card(threat, loop.index) }}
      {% endfor %}
    </ol>

    <!-- ── Mainstream threats list ─────────────────────────────────── -->
    {% if mainstream_threats %}
    <ol class="threat-list" id="threat-list-mainstream" aria-label="Top mainstream cyber threats" hidden>
      {% for threat in mainstream_threats %}
      {{ threat_card(threat, loop.index) }}
      {% endfor %}
    </ol>
    {% else %}
    <div id="threat-list-mainstream" class="no-mainstream" hidden>
      <p>Mainstream coverage data is not yet available. Try running the pipeline again after mainstream sources have been collected.</p>
    </div>
    {% endif %}

    <!-- No results state -->
    <div id="no-results" class="no-results" hidden>
      <p>No threats match your filter. <button class="link-btn js-clear-filters">Clear filters</button></p>
    </div>

    {% else %}
    <div class="empty-state">
      <h2>No threat data available</h2>
      <p>The pipeline has not yet generated output, or no items were collected. Run the pipeline and check the logs.</p>
    </div>
    {% endif %}

  </div><!-- /container -->
</main>

<!-- ═══════════════════════════════════════════════════════ SOURCES -->
{% if sources_queried %}
<section class="sources-section" aria-label="Intelligence sources">
  <div class="container">
    <div class="sources-header">
      <h2 class="section-heading">Intelligence sources</h2>
      <p class="sources-intro" id="sources-intro">
        <span id="sources-count">{{ sources_queried|length }}</span> sources were queried for today&rsquo;s briefing.
        Sources are weighted by credibility (0&ndash;100) when ranking threats.
      </p>
    </div>

    <div class="sources-grid" id="sources-grid">
      {% for source in sources_queried %}
      <div class="source-card" data-stream="{{ source.stream }}">
        <div class="source-card-top">
          <span class="source-card-name">{{ source.name }}</span>
          <span class="source-cred-badge source-cred-badge--{% if source.credibility >= 0.9 %}high{% elif source.credibility >= 0.8 %}med{% else %}std{% endif %}"
                aria-label="Credibility score: {{ source.credibility_pct }}/100"
                {% if source.rationale %}data-rationale="{{ source.rationale }}"{% endif %}>
            {{ source.credibility_pct }}
          </span>
        </div>
        {% if source.rationale %}
        <p class="source-rationale">{{ source.rationale }}</p>
        {% endif %}
        <div class="source-card-tags">
          {% for tag in source.tags %}
          <span class="source-tag">{{ tag }}</span>
          {% endfor %}
        </div>
      </div>
      {% endfor %}
    </div>

    <div class="sources-toggle-row" id="sources-toggle-row" hidden>
      <button id="sources-toggle" class="sources-toggle-btn" aria-expanded="false">
        Show more sources
      </button>
    </div>
  </div>
</section>
{% endif %}

<!-- ═══════════════════════════════════════════════════════ FEED TUTORIAL -->
<section class="methodology feed-section">
  <div class="container">
    <details class="collapsible-section">
      <summary class="collapsible-summary">
        <span>Using the data feeds</span>
        <span class="collapsible-chevron" aria-hidden="true">&#8964;</span>
      </summary>
      <div class="collapsible-body">
        <p class="methodology-intro">All three services expose machine-readable JSON feeds that update daily.</p>
        <div class="feed-grid">
          <div class="feed-card">
            <h3 class="feed-card__title">&#9888; Cyber Threats Feed</h3>
            <p class="feed-card__desc">Daily top-10 cyber threat intelligence briefing.</p>
            <code class="feed-card__url">latest.json</code>
            <div class="code-block-wrap">
              <button class="copy-code-btn">Copy</button>
              <pre class="code-block"><code>curl -s https://bcheevers123.github.io/threat-landscape/latest.json \
  | python3 -m json.tool</code></pre>
            </div>
          </div>
          <div class="feed-card">
            <h3 class="feed-card__title">&#129302; AI/ML Feed</h3>
            <p class="feed-card__desc">Daily top-10 AI and machine learning developments.</p>
            <code class="feed-card__url">aiml/latest.json</code>
            <div class="code-block-wrap">
              <button class="copy-code-btn">Copy</button>
              <pre class="code-block"><code>curl -s https://bcheevers123.github.io/threat-landscape/aiml/latest.json \
  | python3 -m json.tool</code></pre>
            </div>
          </div>
          <div class="feed-card">
            <h3 class="feed-card__title">&#128197; Conferences Feed</h3>
            <p class="feed-card__desc">Upcoming cybersecurity events for the next 12 months.</p>
            <code class="feed-card__url">conferences/latest.json</code>
            <div class="code-block-wrap">
              <button class="copy-code-btn">Copy</button>
              <pre class="code-block"><code>curl -s https://bcheevers123.github.io/threat-landscape/conferences/latest.json \
  | python3 -m json.tool</code></pre>
            </div>
          </div>
        </div>
        <div class="feed-tutorial-detail">
          <h3>Python example — today&rsquo;s top threats</h3>
          <div class="code-block-wrap">
            <button class="copy-code-btn">Copy</button>
            <pre class="code-block"><code>import requests
url = "https://bcheevers123.github.io/threat-landscape/latest.json"
data = requests.get(url, timeout=10).json()
