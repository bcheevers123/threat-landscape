# Copy this file to .env and fill in your values.
# The .env file must NEVER be committed to source control.

# --- SFTP deployment credentials ---
SFTP_HOST=your-webhost.example.com
SFTP_PORT=22
SFTP_USER=your_ssh_username
# Path to your SSH private key (preferred over password auth)
SFTP_KEY_PATH=~/.ssh/id_rsa
# Alternatively use password auth (less secure)
# SFTP_PASSWORD=your_sftp_password

# --- Optional LLM enrichment (leave blank to use deterministic mode) ---
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# --- Optional: override config path ---
# CONFIG_PATH=/home/pi/threat-landscape/config/config.yaml
# SOURCES_PATH=/home/pi/threat-landscape/config/sources.yaml
